{
  "name": "flowscript-react",
  "description": "FlowScript - Visual Programming Tool",
  "author": "FlowScript",
  "private": true,
  "version": "0.3.2",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "electron:dev": "vite --config vite.electron.config.mjs",
    "build": "vite build",
    "electron:build": "vite build --config vite.electron.config.mjs && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.flowscript.app",
    "productName": "FlowScript",
    "icon": "public/FlowScript_Logo.png",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extends": null,
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "@monaco-editor/react": "^4.7.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "reactflow": "^11.11.4",
    "uuid": "^14.0.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^32.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^0.29.1",
    "wait-on": "^9.0.10"
  }
}
